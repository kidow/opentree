{
  "name": "opentree-cli",
  "version": "0.1.0",
  "description": "CLI for bootstrapping an opentree profile site",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kidow/opentree.git"
  },
  "homepage": "https://github.com/kidow/opentree#readme",
  "bugs": {
    "url": "https://github.com/kidow/opentree/issues"
  },
  "keywords": [
    "cli",
    "link-in-bio",
    "profile",
    "static-site",
    "opentree"
  ],
  "files": [
    "bin",
    "src",
    "opentree.schema.json"
  ],
  "bin": {
    "opentree": "./bin/opentree.js"
  },
  "scripts": {
    "start": "node ./bin/opentree.js",
    "release:check": "npm test && npm run test:smoke",
    "prepublishOnly": "npm run release:check",
    "test": "node --test",
    "test:smoke": "node ./scripts/cli-smoke.js"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
