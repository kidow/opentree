{
  "productName": "Opentree",
  "version": "0.1.0",
  "identifier": "dev.kidow.opentree",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Opentree",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English", "Korean"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/kidow/opentree/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0QUVEMEYyNDc0MTc2MjEKUldRaGRrRkg4dEN1dEVTTGplY3F3NUZGNkxtOUhvODdRb051Sk42TGtnYXdJSU4rU092cmIxZU0K"
    }
  }
}
