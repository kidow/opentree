---
import '@fontsource-variable/inter';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import Header from '../components/Header.astro';
import { getLangFromUrl, stripLocale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);

const defaults = {
  en: {
    title: 'Opentree — link-in-bio on your computer',
    description: 'Visual editor, live preview, one-click deploy. Your data stays on disk as a single JSON file.',
  },
  ko: {
    title: 'Opentree — 내 컴퓨터에서 만드는 링크인바이오',
    description: '비주얼 에디터, 실시간 미리보기, 원클릭 배포. 데이터는 단일 JSON 파일로 디스크에 저장됩니다.',
  },
}[lang];

const {
  title = defaults.title,
  description = defaults.description,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og.png', Astro.site).href;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/ko/' || Astro.url.pathname === '/ko';

const basePath = stripLocale(Astro.url.pathname);
const enUrl = new URL(basePath, Astro.site).href;
const koUrl = new URL(basePath === '/' ? '/ko/' : `/ko${basePath}`, Astro.site).href;

const ogLocale = lang === 'ko' ? 'ko_KR' : 'en_US';

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Opentree',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: ['macOS', 'Windows'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  url: Astro.site?.href ?? 'https://opentree.page/',
  author: {
    '@type': 'Person',
    name: 'kidow',
    url: 'https://github.com/kidow',
  },
};
---

<!doctype html>
<html lang={lang === 'ko' ? 'ko' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="kidow" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <meta property="og:site_name" content="Opentree" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={isHome ? 'website' : 'article'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Opentree — link-in-bio on your computer" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
    )}
  </head>
  <body class="bg-canvas text-ink font-sans antialiased dark:bg-canvas-dark dark:text-white">
    <Header />
    <slot />
  </body>
</html>
