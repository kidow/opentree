---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Author from '../components/Author.astro';
import Footer from '../components/Footer.astro';

const configExample = JSON.stringify(
  {
    schemaVersion: 1,
    profile: {
      name: 'Your Name',
      bio: 'Your bio here',
    },
    blocks: [
      { type: 'link', title: 'My Website', url: 'https://example.com' },
      { type: 'heading', text: 'Projects' },
      { type: 'link', title: 'GitHub', url: 'https://github.com/you' },
    ],
  },
  null,
  2
);
---

<BaseLayout>
  <Hero />

  <Section
    label="Local-first"
    title="Just a JSON file on your disk"
    body="Opentree stores your entire link page in a single opentree.config.json file. No database, no cloud sync — just a file you own and can move, back up, or version-control however you like."
  >
    <div class="rounded-xl overflow-hidden border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900">
      <div class="px-4 py-2 border-b border-neutral-200 dark:border-neutral-800 flex items-center gap-2">
        <span class="text-xs font-mono text-neutral-400">opentree.config.json</span>
      </div>
      <pre class="p-4 text-xs font-mono text-neutral-800 dark:text-neutral-200 overflow-x-auto leading-relaxed"><code>{configExample}</code></pre>
    </div>
  </Section>

  <Section
    label="Editor"
    title="Drag, drop, done"
    body="Add links, headings, or text blocks with a click. Reorder them by dragging. Every change is undoable — no autosave surprises, no lost work."
  >
    <div class="grid grid-cols-3 gap-2">
      {['Link', 'Heading', 'Text'].map((type) => (
        <div class="rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 px-4 py-3 text-center text-sm font-medium text-neutral-700 dark:text-neutral-300">
          {type}
        </div>
      ))}
    </div>
  </Section>

  <Section
    label="Preview"
    title="See it before you ship"
    body="A live phone-shaped preview updates as you edit. What you see is exactly what your visitors will see — no surprises after deploy."
  >
    <div class="flex justify-center">
      <div class="w-36 rounded-3xl border-4 border-neutral-300 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900 aspect-[9/19] flex flex-col items-center justify-center gap-2 p-3">
        <div class="w-full h-2 rounded-full bg-neutral-300 dark:bg-neutral-700"></div>
        <div class="w-3/4 h-2 rounded-full bg-neutral-200 dark:bg-neutral-800"></div>
        <div class="w-full h-6 rounded-md bg-accent/20 mt-1"></div>
        <div class="w-full h-6 rounded-md bg-neutral-200 dark:bg-neutral-800"></div>
        <div class="w-full h-6 rounded-md bg-neutral-200 dark:bg-neutral-800"></div>
      </div>
    </div>
  </Section>

  <Section
    label="Deploy"
    title="One click to live"
    body="Publish your page directly from the app. Opentree sends your config to any host that accepts a REST deploy — no CLI, no terminal, no build step on your end."
  >
    <div class="flex items-center gap-3">
      <button
        type="button"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-white font-semibold text-sm cursor-default"
        aria-hidden="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        Publish
      </button>
      <span class="text-sm text-neutral-400">→</span>
      <span class="text-sm text-neutral-600 dark:text-neutral-400 font-mono">your-site.example.com</span>
    </div>
  </Section>

  <Section
    label="Open"
    title="Apache 2.0, no account, no tracking"
    body="The source is public, the license is permissive, and there is nothing to sign up for. Your config file stays on your machine. We collect no analytics, no telemetry, nothing."
  >
    <div class="flex flex-wrap gap-2">
      {['Apache 2.0', 'No account', 'No tracking', 'Your data'].map((tag) => (
        <span class="inline-block px-3 py-1 rounded-full border border-neutral-200 dark:border-neutral-800 text-xs text-neutral-600 dark:text-neutral-400">
          {tag}
        </span>
      ))}
    </div>
  </Section>

  <Author />
  <Footer />
</BaseLayout>
