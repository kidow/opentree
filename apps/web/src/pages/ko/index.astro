---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Author from '../../components/Author.astro';
import Footer from '../../components/Footer.astro';

const blockNames = [
  '링크', '제목', '본문', '푸터 노트', '소셜 아이콘',
  '이미지', '음악 임베드', '비디오 임베드', 'Pinterest 핀',
  '제휴 (UTM)', '광고', 'Custom HTML', '블록 그룹',
  '문의 폼', '이메일 구독',
  '상품', '후원', '코스',
  '언어 전환',
];

const capabilities = [
  {
    title: '블록 스케줄링',
    body: '블록별 게시/내림 시각 지정. 윈도우 밖이면 렌더링된 HTML에 아예 포함되지 않음 — 크롤러와 검색엔진에도 안 보임.',
    icon: 'clock',
  },
  {
    title: '다국어',
    body: '하나의 config로 여러 언어 변형 정의. 각 번역은 자신의 서브디렉토리로 빌드되며 언어 전환 블록 제공.',
    icon: 'globe',
  },
  {
    title: '프라이버시 우선 애널리틱스',
    body: '쿠키 없는 애널리틱스 통합. 페이지뷰 + 블록별 클릭 이벤트 기본 제공, 블록당 별도 설정 불필요.',
    icon: 'chart',
  },
  {
    title: 'SEO 준비 완료',
    body: '제목, 설명, Open Graph, JSON-LD, 사이트맵, robots를 프로필에서 자동 생성. 필요 시 모든 필드 직접 오버라이드.',
    icon: 'search',
  },
];
---

<BaseLayout>
  <Hero />

  <Section
    label="로컬 우선"
    title="디스크에 저장되는 단일 JSON 파일"
    body="Opentree는 전체 링크 페이지를 단일 opentree.config.json 파일에 저장합니다. 데이터베이스도, 클라우드 동기화도 없습니다 — 본인이 소유하고 버전 관리하고 백업하는 파일 하나입니다."
  >
    <div class="rounded-2xl overflow-hidden border border-hairline dark:border-hairline-dark bg-surface-code shadow-xl shadow-ink/5">
      <div class="px-4 py-2.5 border-b border-hairline-dark flex items-center gap-2">
        <div class="flex gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
        </div>
        <span class="ml-2 text-[11px] font-mono text-stone">opentree.config.json</span>
      </div>
      <pre class="p-5 text-[12.5px] font-mono leading-relaxed overflow-x-auto"><code><span class="text-stone">{</span>
  <span class="text-[#7cd1f7]">"schemaVersion"</span><span class="text-stone">:</span> <span class="text-accent">14</span><span class="text-stone">,</span>
  <span class="text-[#7cd1f7]">"profile"</span><span class="text-stone">: {</span>
    <span class="text-[#7cd1f7]">"name"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"이름"</span><span class="text-stone">,</span>
    <span class="text-[#7cd1f7]">"bio"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"한 줄 소개"</span>
  <span class="text-stone">},</span>
  <span class="text-[#7cd1f7]">"blocks"</span><span class="text-stone">: [</span>
    <span class="text-stone">{</span> <span class="text-[#7cd1f7]">"type"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"link"</span><span class="text-stone">,</span> <span class="text-[#7cd1f7]">"title"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"내 사이트"</span> <span class="text-stone">},</span>
    <span class="text-stone">{</span> <span class="text-[#7cd1f7]">"type"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"heading"</span><span class="text-stone">,</span> <span class="text-[#7cd1f7]">"text"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"프로젝트"</span> <span class="text-stone">},</span>
    <span class="text-stone">{</span> <span class="text-[#7cd1f7]">"type"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"link"</span><span class="text-stone">,</span> <span class="text-[#7cd1f7]">"title"</span><span class="text-stone">:</span> <span class="text-[#fab387]">"GitHub"</span> <span class="text-stone">}</span>
  <span class="text-stone">]</span>
<span class="text-stone">}</span></code></pre>
    </div>
  </Section>

  <Section
    label="에디터"
    title="드래그, 드롭, 또는 그냥 요청"
    body="블록을 손으로 추가하고 정렬하거나 — AI 패널에 원하는 변경을 설명하세요. 어시스턴트가 도구 호출로 편집을 제안하면 라이브 폰 미리보기로 먼저 확인한 뒤 적용합니다. 수동이든 AI든 모든 변경은 같은 undo 스택에 들어갑니다."
    reverse
  >
    <div class="rounded-2xl border border-hairline dark:border-hairline-dark bg-surface-soft dark:bg-white/[0.03] p-5 space-y-2.5 shadow-xl shadow-ink/5">
      {[
        { type: 'Link', title: '내 사이트', meta: 'example.com' },
        { type: 'Heading', title: '프로젝트', meta: '' },
        { type: 'Link', title: 'GitHub', meta: 'github.com/you' },
      ].map((b) => (
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-canvas dark:bg-white/[0.05] border border-hairline dark:border-hairline-dark">
          <span class="text-stone select-none cursor-grab" aria-hidden="true">⠿</span>
          <span class="text-[10px] font-medium uppercase tracking-wider text-stone w-14">{b.type}</span>
          <span class="flex-1 text-sm font-medium text-ink dark:text-white truncate">{b.title}</span>
          {b.meta && <span class="text-xs font-mono text-stone hidden sm:inline">{b.meta}</span>}
        </div>
      ))}
      <div class="mt-3 pt-3 border-t border-hairline dark:border-hairline-dark space-y-2">
        <div class="flex items-start gap-2">
          <span class="px-1.5 py-0.5 rounded text-[9px] font-semibold uppercase tracking-wider bg-accent/15 text-accent shrink-0 mt-0.5">AI</span>
          <p class="text-xs text-slate dark:text-stone leading-relaxed">"GitHub 아래에 Twitter 링크 추가해줘."</p>
        </div>
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg border border-dashed border-accent/40 bg-accent/5 text-xs">
          <span class="text-accent font-medium">+ Link</span>
          <span class="text-ink dark:text-white font-medium flex-1 truncate">Twitter</span>
          <button class="text-[10px] font-semibold text-accent" type="button" aria-hidden="true">적용</button>
        </div>
      </div>
    </div>
  </Section>

  <Section
    label="블록"
    title="필요한 모든 종류의 블록"
    body="19가지 블록 타입 — 링크와 제목부터 미디어, 임베드, 폼, 커머스, 예약 공지, 그리고 그 외 무엇이든 받아주는 Custom HTML 탈출구까지 기본 제공."
  >
    <div class="grid grid-cols-2 gap-x-3 gap-y-2 text-sm">
      {blockNames.map((b) => (
        <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg bg-surface-soft dark:bg-white/[0.03] border border-hairline dark:border-hairline-dark">
          <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
          <span class="text-ink dark:text-white truncate">{b}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section
    label="미리보기"
    title="배포 전에 먼저 확인"
    body="편집 중에 라이브 폰 미리보기가 실시간 업데이트됩니다. 보이는 그대로 방문자가 보게 됩니다 — 배포 후 놀랄 일 없음."
    reverse
  >
    <div class="flex justify-center">
      <div class="relative w-56 aspect-[9/19] rounded-[2.25rem] border-[6px] border-ink/90 dark:border-white/10 bg-canvas dark:bg-canvas-dark shadow-2xl shadow-ink/20 overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-ink/90 dark:bg-white/10 rounded-b-2xl"></div>
        <div class="pt-10 px-4 flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-accent to-accent-deep"></div>
          <div class="text-center">
            <div class="text-[11px] font-semibold text-ink dark:text-white">이름</div>
            <div class="text-[9px] text-stone">한 줄 소개</div>
          </div>
          <div class="w-full space-y-1.5 mt-2">
            <div class="w-full h-7 rounded-md bg-accent text-white text-[9px] font-medium flex items-center justify-center">내 사이트</div>
            <div class="w-full h-7 rounded-md bg-surface dark:bg-white/[0.07] text-[9px] font-medium text-ink dark:text-white flex items-center justify-center">GitHub</div>
            <div class="w-full h-7 rounded-md bg-surface dark:bg-white/[0.07] text-[9px] font-medium text-ink dark:text-white flex items-center justify-center">Twitter</div>
            <div class="w-full h-7 rounded-md bg-surface dark:bg-white/[0.07] text-[9px] font-medium text-ink dark:text-white flex items-center justify-center">이메일</div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section
    label="배포"
    title="원클릭 배포"
    body="앱에서 바로 세 곳의 호스팅 제공자 중 한 곳으로 게시. REST 기반 배포로 CLI도, 터미널도, 빌드 단계도 필요 없음. 커스텀 도메인도 제공자별 DNS 안내와 함께 지원."
  >
    <div class="rounded-2xl border border-hairline dark:border-hairline-dark bg-surface-soft dark:bg-white/[0.03] p-6 shadow-xl shadow-ink/5">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-stone">상태</span>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-accent">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          라이브
        </span>
      </div>
      <div class="flex items-center gap-3 mb-4">
        <button
          type="button"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-ink text-white text-xs font-medium dark:bg-white dark:text-ink cursor-default"
          aria-hidden="true"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          게시
        </button>
        <span class="text-stone text-sm">→</span>
        <span class="text-xs font-mono text-slate dark:text-stone truncate">your-site.example.com</span>
      </div>
      <div class="text-[11px] font-mono text-stone border-t border-hairline dark:border-hairline-dark pt-3 space-y-1">
        <div>✓ Built config (24ms)</div>
        <div>✓ Uploaded 1 file (217ms)</div>
        <div class="text-accent">✓ Deployed</div>
      </div>
    </div>
  </Section>

  <section class="px-6 py-20 sm:py-24 border-t border-hairline dark:border-hairline-dark">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-2xl mb-10">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-accent mb-4">기본 제공</p>
        <h2 class="text-heading-1 text-ink dark:text-white mb-5">그 외 모든 것도 기본 탑재</h2>
        <p class="text-base sm:text-lg text-slate dark:text-stone leading-relaxed">
          설치할 플러그인 없음. 호스팅할 별도 서비스 없음. 지루한 인프라는 앱과 함께 들어옵니다.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {capabilities.map((cap) => (
          <div class="p-5 rounded-xl border border-hairline dark:border-hairline-dark bg-surface-soft dark:bg-white/[0.03]">
            <div class="w-8 h-8 rounded-lg bg-accent/10 text-accent flex items-center justify-center mb-3">
              {cap.icon === 'clock' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              )}
              {cap.icon === 'globe' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              )}
              {cap.icon === 'chart' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
              )}
              {cap.icon === 'search' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="8"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
              )}
            </div>
            <h3 class="text-sm font-semibold text-ink dark:text-white mb-1.5">{cap.title}</h3>
            <p class="text-xs text-stone leading-relaxed">{cap.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Section
    label="오픈"
    title="Apache 2.0, 계정 불필요, 추적 없음"
    body="소스는 공개되어 있고, 라이선스는 관대하며, 가입할 곳이 없습니다. config 파일은 사용자 기기에 머무릅니다. 애널리틱스도, 텔레메트리도, 그 무엇도 수집하지 않습니다."
    reverse
  >
    <div class="grid grid-cols-2 gap-3">
      {[
        { title: 'Apache 2.0', body: '관대한 라이선스' },
        { title: '로컬 우선', body: '내 데이터, 내 디스크' },
        { title: '추적 없음', body: '텔레메트리 영구 차단' },
        { title: '계정 불필요', body: '다운로드만 하면 끝' },
      ].map((f) => (
        <div class="p-4 rounded-xl border border-hairline dark:border-hairline-dark bg-surface-soft dark:bg-white/[0.03]">
          <div class="flex items-center gap-2 mb-1.5">
            <svg class="text-accent" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-sm font-semibold text-ink dark:text-white">{f.title}</span>
          </div>
          <p class="text-xs text-stone">{f.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Author />
  <Footer />
</BaseLayout>
