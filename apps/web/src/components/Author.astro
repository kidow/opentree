---
const GITHUB_URL = 'https://github.com/kidow/opentree';
---

<section class="px-6 py-10 border-t border-hairline dark:border-hairline-dark">
  <div class="max-w-2xl mx-auto text-center text-xs text-stone">
    Built by{' '}
    <a
      href="https://github.com/kidow"
      target="_blank"
      rel="noopener noreferrer"
      class="text-slate dark:text-muted hover:text-accent transition-colors"
    >
      kidow
    </a>
    {' · '}
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono hover:text-accent transition-colors"
    >
      github.com/kidow/opentree
    </a>
  </div>
</section>
