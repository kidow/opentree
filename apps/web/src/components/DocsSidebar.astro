---
import { getLangFromUrl, useTranslations, localizedHref, stripLocale } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = stripLocale(Astro.url.pathname.replace(/\/$/, ''));

interface Item {
  label: string;
  base: string;
  children?: { label: string; base: string }[];
}

interface Group {
  title: string;
  items: Item[];
}

const groups: Group[] = [
  {
    title: t('sidebar.overview'),
    items: [{ label: t('sidebar.introduction'), base: '/docs' }],
  },
  {
    title: t('sidebar.editing'),
    items: [
      {
        label: t('sidebar.blocks'),
        base: '/docs/blocks',
        children: [
          { label: t('sidebar.blocks.basic'), base: '/docs/blocks/basic' },
          { label: t('sidebar.blocks.media'), base: '/docs/blocks/media' },
          { label: t('sidebar.blocks.forms'), base: '/docs/blocks/forms' },
          { label: t('sidebar.blocks.commerce'), base: '/docs/blocks/commerce' },
        ],
      },
      { label: t('sidebar.design'), base: '/docs/design' },
      { label: t('sidebar.aichat'), base: '/docs/ai-chat' },
      { label: t('sidebar.scheduling'), base: '/docs/scheduling' },
    ],
  },
  {
    title: t('sidebar.publishing'),
    items: [
      { label: t('sidebar.deploy'), base: '/docs/deploy' },
      { label: t('sidebar.domains'), base: '/docs/domains' },
      { label: t('sidebar.seo'), base: '/docs/seo' },
      { label: t('sidebar.i18n'), base: '/docs/i18n' },
      { label: t('sidebar.analytics'), base: '/docs/analytics' },
    ],
  },
  {
    title: t('sidebar.reference'),
    items: [
      { label: t('sidebar.schema'), base: '/docs/schema' },
      { label: t('sidebar.troubleshooting'), base: '/docs/troubleshooting' },
    ],
  },
];

const isActive = (base: string) => path === base;
---

<nav class="space-y-7 text-sm">
  {groups.map((group) => (
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-stone mb-3 px-3">
        {group.title}
      </p>
      <ul class="space-y-0.5">
        {group.items.map((item) => (
          <li>
            <a
              href={localizedHref(item.base, lang)}
              class:list={[
                'block px-3 py-1.5 rounded-md transition-colors',
                isActive(item.base)
                  ? 'text-accent font-medium bg-accent/10'
                  : 'text-slate dark:text-stone hover:text-ink dark:hover:text-white hover:bg-surface dark:hover:bg-white/[0.04]',
              ]}
            >
              {item.label}
            </a>
            {item.children && (
              <ul class="mt-0.5 ml-3 pl-3 border-l border-hairline dark:border-hairline-dark space-y-0.5">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={localizedHref(child.base, lang)}
                      class:list={[
                        'block px-3 py-1.5 rounded-md transition-colors text-[13px]',
                        isActive(child.base)
                          ? 'text-accent font-medium bg-accent/10'
                          : 'text-stone hover:text-ink dark:hover:text-white hover:bg-surface dark:hover:bg-white/[0.04]',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
