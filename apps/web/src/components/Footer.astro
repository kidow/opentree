---
import { getLangFromUrl, useTranslations, localizedHref } from '../i18n/utils';

const year = new Date().getFullYear();
const GITHUB_URL = 'https://github.com/kidow/opentree';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="px-6 py-10 border-t border-hairline dark:border-hairline-dark">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-stone">
    <span>© {year} Opentree · Apache 2.0</span>
    <div class="flex items-center gap-5">
      <a
        href={localizedHref('/download', lang)}
        class="hover:text-ink dark:hover:text-white transition-colors"
      >
        {t('footer.download')}
      </a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-ink dark:hover:text-white transition-colors"
      >
        {t('footer.github')}
      </a>
    </div>
  </div>
</footer>
