---
interface Props {
  label: string;
  title: string;
  body: string;
}

const { label, title, body } = Astro.props;
---

<section class="px-6 py-20 border-t border-neutral-200 dark:border-neutral-800">
  <div class="max-w-2xl mx-auto">
    <p class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-3">
      {label}
    </p>
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-4">
      {title}
    </h2>
    <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-8 max-w-lg">
      {body}
    </p>
    <slot />
  </div>
</section>
