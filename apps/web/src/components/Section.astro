---
interface Props {
  label: string;
  title: string;
  body: string;
  reverse?: boolean;
}

const { label, title, body, reverse = false } = Astro.props;
---

<section class="px-6 py-20 sm:py-24 border-t border-hairline dark:border-hairline-dark">
  <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class={reverse ? 'lg:order-2' : ''}>
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-accent mb-4">
        {label}
      </p>
      <h2 class="text-heading-1 text-ink dark:text-white mb-5">
        {title}
      </h2>
      <p class="text-base sm:text-lg text-slate dark:text-stone leading-relaxed max-w-md">
        {body}
      </p>
    </div>
    <div class={reverse ? 'lg:order-1' : ''}>
      <slot />
    </div>
  </div>
</section>
