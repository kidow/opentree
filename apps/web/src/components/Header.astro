---
import { SearchCommand } from './SearchCommand';
import { LanguageSwitcher } from './LanguageSwitcher';
import { getLangFromUrl, useTranslations, localizedHref, stripLocale } from '../i18n/utils';

const GITHUB_URL = 'https://github.com/kidow/opentree';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = stripLocale(Astro.url.pathname.replace(/\/$/, ''));

const navItems = [
  { label: t('nav.docs'), href: localizedHref('/docs', lang), basePath: '/docs' },
  { label: t('nav.download'), href: localizedHref('/download', lang), basePath: '/download' },
];

function isActive(basePath: string) {
  if (basePath === '/') return path === '';
  return path === basePath || path.startsWith(basePath + '/');
}
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-canvas/75 dark:bg-canvas-dark/75 border-b border-hairline dark:border-hairline-dark">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 min-w-0">
      <a href={localizedHref('/', lang)} class="flex items-center gap-2 group shrink-0" aria-label="Opentree home">
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-md bg-accent">
          <svg width="14" height="14" viewBox="0 0 32 32" aria-hidden="true">
            <polygon points="16,3 23,13 19,13 22,20 10,20 13,13 9,13" fill="white"/>
            <rect x="14" y="20" width="4" height="8" fill="white"/>
          </svg>
        </span>
        <span class="text-sm font-semibold tracking-tight text-ink dark:text-white">Opentree</span>
      </a>
      <div class="hidden sm:block">
        <SearchCommand client:idle lang={lang} />
      </div>
    </div>

    <nav class="flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-1.5 rounded-full text-sm font-medium transition-colors',
            isActive(item.basePath)
              ? 'text-ink dark:text-white bg-surface dark:bg-white/[0.06]'
              : 'text-slate dark:text-stone hover:text-ink dark:hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="ml-2 hidden sm:block">
        <LanguageSwitcher client:idle lang={lang} pathname={Astro.url.pathname} />
      </div>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 p-2 rounded-full text-slate dark:text-stone hover:text-ink dark:hover:text-white transition-colors"
        aria-label="GitHub repository"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </nav>
  </div>
</header>
