---
import { getLangFromUrl, stripLocale } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const basePath = stripLocale(Astro.url.pathname);

const links = (Object.keys(languages) as Array<keyof typeof languages>).map((code) => ({
  code,
  label: languages[code],
  href: code === 'en' ? basePath : `/${code}${basePath === '/' ? '/' : basePath}`,
  active: code === lang,
}));
---

<div class="inline-flex items-center gap-0.5 p-0.5 rounded-full border border-hairline dark:border-hairline-dark bg-surface-soft dark:bg-white/[0.04]" role="group" aria-label="Language">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'inline-flex items-center justify-center px-2.5 h-7 rounded-full text-xs font-medium transition-colors',
        link.active
          ? 'bg-canvas dark:bg-white/[0.08] text-ink dark:text-white shadow-sm'
          : 'text-stone hover:text-ink dark:hover:text-white',
      ]}
      aria-current={link.active ? 'true' : undefined}
    >
      {link.code === 'en' ? 'EN' : 'KO'}
    </a>
  ))}
</div>
