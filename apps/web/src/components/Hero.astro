---
const GITHUB_URL = 'https://github.com/kidow/opentree';
---

<section class="px-6 py-24 sm:py-32">
  <div class="max-w-2xl mx-auto text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-6">
      Link-in-bio
    </p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 leading-tight mb-6">
      Your link-in-bio,<br />on your computer.<br />
      <span class="text-accent">Free forever.</span>
    </h1>
    <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-10 max-w-xl mx-auto leading-relaxed">
      Visual editor, live preview, one-click deploy. Your data stays on disk as a single JSON file.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-6">
      <a
        href="/download"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-green-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for macOS
      </a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 font-semibold text-sm hover:border-neutral-400 dark:hover:border-neutral-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>
    <p class="text-sm text-neutral-500 dark:text-neutral-500">
      Open source, free forever, no account required.
    </p>
  </div>
</section>
