---
import { getLangFromUrl, localizedHref } from '../i18n/utils';

const GITHUB_URL = 'https://github.com/kidow/opentree';
const lang = getLangFromUrl(Astro.url);

const copy = {
  en: {
    badge: 'Now in public beta — macOS · Windows',
    headline1: 'Your link-in-bio,',
    headline2: 'on your computer.',
    headlineAccent: 'Free forever.',
    sub1: 'Visual editor, AI-assisted, multi-platform deploy.',
    sub2: 'Your data stays on disk as a single JSON file.',
    ctaPrimary: 'Download Opentree',
    ctaSecondary: 'Star on GitHub',
    tagline: 'Open source · Apache 2.0 · No account required',
  },
  ko: {
    badge: '공개 베타 — macOS · Windows',
    headline1: '내 컴퓨터에서 만드는',
    headline2: '링크인바이오.',
    headlineAccent: '평생 무료.',
    sub1: '비주얼 에디터, AI 편집, 멀티 플랫폼 배포.',
    sub2: '데이터는 단일 JSON 파일로 디스크에 저장됩니다.',
    ctaPrimary: 'Opentree 다운로드',
    ctaSecondary: 'GitHub 스타',
    tagline: '오픈소스 · Apache 2.0 · 계정 불필요',
  },
}[lang];
---

<section class="relative hero-backdrop overflow-hidden">
  <div class="absolute inset-0 grid-fade opacity-60 pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 pt-16 pb-20 sm:pt-24 sm:pb-28 lg:pt-32 lg:pb-36 text-center">
    <a
      href="https://github.com/kidow/opentree/releases/latest"
      class="inline-flex items-center gap-2 px-3 py-1 mb-8 rounded-full border border-hairline bg-white/70 backdrop-blur text-xs font-medium text-slate hover:border-stone transition-colors dark:bg-white/5 dark:border-hairline-dark dark:text-stone"
    >
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      <span>{copy.badge}</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <h1 class="text-hero-display text-ink dark:text-white mb-6">
      {copy.headline1}<br class="hidden sm:block" />
      {copy.headline2}<br />
      <span class="text-accent">{copy.headlineAccent}</span>
    </h1>

    <p class="text-lg sm:text-xl text-slate dark:text-stone leading-relaxed max-w-2xl mx-auto mb-10">
      {copy.sub1}<br class="hidden sm:block" />
      {copy.sub2}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-6">
      <a
        href={localizedHref('/download', lang)}
        class="group inline-flex items-center gap-2 px-6 py-3 rounded-full bg-ink text-white font-medium text-sm hover:bg-charcoal transition-colors dark:bg-white dark:text-ink dark:hover:bg-stone"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/>
        </svg>
        {copy.ctaPrimary}
        <svg class="opacity-60 group-hover:translate-x-0.5 transition-transform" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-hairline bg-white text-ink font-medium text-sm hover:border-stone hover:bg-surface transition-colors dark:bg-white/5 dark:border-hairline-dark dark:text-white dark:hover:bg-white/10"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        {copy.ctaSecondary}
      </a>
    </div>

    <p class="text-xs text-stone dark:text-muted">
      {copy.tagline}
    </p>
  </div>
</section>
